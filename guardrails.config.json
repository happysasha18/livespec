{
  "spec_path": "PRODUCT_SPEC.md",
  "matrix_path": "TEST_MATRIX.md",
  "queue_path": "ROADMAP.md",
  "tests_dir": "tests",
  "user_facing_globs": [
    "skills/**/SKILL.md",
    "scripts/*.py",
    "guardrails/*.sh",
    "scaffold/guardrails/*.py",
    "README.md"
  ],
  "registry_path": "SURFACES.md",
  "render_command": null,
  "rendered_artifacts": [
    "README.md",
    "OVERVIEW.md"
  ],
  "surface_discovery_pattern": "<section id=\"([^\"]+)\"",
  "waivers": {},
  "reach_classes": {
    "prose_files": ["README.md", "OVERVIEW.md", "MIGRATION.md", "LICENSE"],
    "prose_dirs": ["docs/research", "docs/reports", "docs/audit", "docs/decisions"],
    "infra_dirs": ["guardrails", "scaffold/guardrails", "templates", "scripts", "hooks", "adopt"],
    "infra_files": ["guardrails.config.json"],
    "infra_globs": ["tests/test_*.py"],
    "referrer_dirs": ["guardrails", "scaffold/guardrails", "scripts", "templates", "hooks", "adopt"]
  }
}
