#!/usr/bin/env bash
# pre-push — the live-spec push gate (SPEC M-6; scope grown by prover findings F7/F4;
# gate e added for INV-17, the prototype fence).
# Blocks a push unless every gate below passes.
#
# Generic pattern for a host project: copy this file, then in guardrails/README.md's
# "how a host adapts" section swap in your own test command and prover cadence — the
# gate shape (fresh review record / green tests / ownership / coverage) travels as-is.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"
GUARDRAILS="$REPO_ROOT/guardrails"

fail=0

echo "== live-spec push gate =="

echo ""
echo "-- gate a: fresh prover record for today --"
if ! "$GUARDRAILS/check-prover-record.sh"; then
  fail=1
fi

echo ""
echo "-- gate b: test suite green (scoped by the diff's reach, SPEC INV-45) --"
set +e
reach_out="$("$GUARDRAILS/check-push-reach.sh")"
reach_code=$?
set -e
echo "$reach_out"
case "$reach_code" in
  0)
    echo "   prose-only diff: the suite stands down by name; every other gate still runs."
    ;;
  2)
    scoped_files="$(printf '%s\n' "$reach_out" | sed -n 's/^SCOPED //p')"
    if ! SCOPED_TEST_FILES="$scoped_files" "$GUARDRAILS/check-tests.sh"; then
      fail=1
    fi
    ;;
  *)
    if ! "$GUARDRAILS/check-tests.sh"; then
      fail=1
    fi
    ;;
esac

echo ""
echo "-- gate c: every spec anchor owned by exactly one architecture node --"
echo "   Covered by gate b: tests/test_traceability.py already asserts this"
echo "   (test_architecture_owns_every_anchor_once) — no separate check needed here."

echo ""
echo "-- gate d: TEST_MATRIX.md coverage-validation fully checked --"
if ! "$GUARDRAILS/check-matrix-coverage.sh"; then
  fail=1
fi

echo ""
echo "-- gate g: pin drift --"
if ! "$GUARDRAILS/check-pin-drift.sh"; then
  fail=1
fi

echo "-- gate f: skill loadability --"
if ! "$GUARDRAILS/check-skill-loadability.sh"; then
  fail=1
fi

echo "-- gate e: prototype fence --"
if ! "$GUARDRAILS/check-prototype-fence.sh"; then
  fail=1
fi

echo "-- gate i: shipped-language (no owner name or stray Cyrillic in the shipped set, SPEC INV-120) --"
if ! "$GUARDRAILS/check-shipped-language.sh"; then
  fail=1
fi

echo ""
echo "-- gate j: no broad browser-kill (cleanup targets the test resource only, SPEC INV-162) --"
if ! "$GUARDRAILS/check-broad-kill.sh"; then
  fail=1
fi

echo ""
echo "-- gate l: muted browser launch (every browser-driving script launches muted, SPEC INV-157) --"
if ! "$GUARDRAILS/check-muted-launch.sh"; then
  fail=1
fi

echo ""
echo "-- gate o: cleanup notice (every cleanup path that ends a process says what it ended, SPEC INV-204) --"
if ! "$GUARDRAILS/check-cleanup-notice.sh"; then
  fail=1
fi

echo ""
echo "-- gate p: touchpoint kind (a surface speaks only the kind its touchpoint affords, SPEC INV-205) --"
if ! python3 "$GUARDRAILS/check-touchpoint-kind.py"; then
  fail=1
fi

echo ""
echo "-- gate q: waiting list (the board loses nothing — no over-cap shown set, no demotion into the void, SPEC INV-206) --"
if ! python3 "$GUARDRAILS/check-board.py"; then
  fail=1
fi

echo ""
echo "-- gate r: authority anchor (a decision recorded as the person's names its exchange, SPEC INV-207) --"
if ! python3 "$GUARDRAILS/check-authority-anchor.py"; then
  fail=1
fi

echo ""
echo "-- gate m: config health (installed hooks match guardrails/ source, SPEC INV-175) --"
if ! "$GUARDRAILS/check-config-health.sh"; then
  fail=1
fi

echo ""
echo "-- gate k: compaction freeze (guarded docs' anchor map / markers / numbers unchanged, 2.0) --"
if ! "$GUARDRAILS/check-freeze.sh"; then
  fail=1
fi

echo ""
echo "-- gate n: the earned message (an agent's inbox deposit names its birth, SPEC INV-189) --"
if [ -f "$GUARDRAILS/check-earned-message.py" ] && [ -d "$REPO_ROOT/inbox" ]; then
  if ! python3 "$GUARDRAILS/check-earned-message.py" "$REPO_ROOT/inbox"; then
    fail=1
  fi
else
  echo "   (no inbox in this tree — the gate stands down by name)"
fi

echo ""
echo "-- gate h: the four host checks (this repo attached as its own first host, SPEC INV-97) --"
for hostcheck in completeness tests_present traces_to_spec conflicts; do
  if ! python3 "$REPO_ROOT/scaffold/guardrails/check_${hostcheck}.py" --base origin/main; then
    fail=1
  fi
done

echo ""
if [ "$fail" -ne 0 ]; then
  echo "PUSH BLOCKED — one or more gates above failed. Fix them and try again."
  exit 1
fi

# The gates are green, so this push is about to land — sync the standalone mirror repos
# from the pack now, so a mirror never drifts behind a shipped pack version again (a mirror
# was found one version behind on 2026-07-13). This runs ONLY past the blocked-push exit
# above, so a blocked push never reaches a mirror. It is NON-BLOCKING: a mirror hiccup
# (gh not authenticated, no network) warns and lets the pack push through — the CI arm and
# the next push both re-sync. Extends the push gate (SPEC M-6) and the mirror mechanism
# (scripts/sync-mirrors.sh, SPEC INV-96).
echo ""
echo "-- mirror sync (non-blocking) --"
if "$REPO_ROOT/scripts/sync-mirrors.sh"; then
  :
else
  echo "   warn: mirror sync did not complete (gh auth? network?) — run scripts/sync-mirrors.sh by hand."
fi

echo "All gates green — push allowed."
exit 0
