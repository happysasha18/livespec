#!/usr/bin/env bash
# pre-commit — the concurrent-edit fence (SPEC INV-11).
#
# OPT-IN by design: a session arms the fence by running guardrails/fence-refresh.sh,
# which writes the HEAD sha it last saw into .live-spec-fence (untracked, repo root).
#
# If .live-spec-fence is ABSENT, this hook passes silently — the fence is not armed,
# and that is deliberate, not a bug to "fix". If present and HEAD has moved since it
# was recorded, another writer touched the repo; the commit is blocked until the
# fence is reviewed and refreshed.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
FENCE_FILE="$REPO_ROOT/.live-spec-fence"

# INV-24 second arm (row 104): no staged line stamps today with a future time.
if [ -x "$REPO_ROOT/guardrails/check-future-times.sh" ]; then
  "$REPO_ROOT/guardrails/check-future-times.sh" || exit 1
fi

# INV-152 net: a parked-for-the-human item in the resume file or a decision page must
# name its human-only fact (taste / policy / irreversible / device-feel), else it is
# the seat's to do. Scans NEXT_STEPS.md and any docs/decisions/*.md.
if [ -f "$REPO_ROOT/guardrails/check-deferral-marker.py" ]; then
  deferral_targets=""
  [ -f "$REPO_ROOT/NEXT_STEPS.md" ] && deferral_targets="$REPO_ROOT/NEXT_STEPS.md"
  for d in "$REPO_ROOT"/docs/decisions/*.md; do
    [ -f "$d" ] && deferral_targets="$deferral_targets $d"
  done
  if [ -n "$deferral_targets" ]; then
    # shellcheck disable=SC2086
    python3 "$REPO_ROOT/guardrails/check-deferral-marker.py" $deferral_targets || exit 1
  fi
fi

if [ ! -f "$FENCE_FILE" ]; then
  exit 0
fi

recorded_sha="$(tr -d '[:space:]' < "$FENCE_FILE")"
current_sha="$(git -C "$REPO_ROOT" rev-parse HEAD)"

if [ "$recorded_sha" != "$current_sha" ]; then
  echo "COMMIT BLOCKED — the concurrent-edit fence is armed and HEAD has moved."
  echo "  Recorded HEAD: $recorded_sha"
  echo "  Current HEAD:  $current_sha"
  echo "  Someone else committed or pulled into this repo since your session started."
  echo "  Review what changed (e.g. git log $recorded_sha..$current_sha), then refresh"
  echo "  the fence once you've accounted for it:"
  echo "    guardrails/fence-refresh.sh"
  exit 1
fi

exit 0
