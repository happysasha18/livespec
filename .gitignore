.live-spec/checkpoints/

# outbox/ holds private upstream notes (feedback-collector) — never tracked, never pushed
outbox/
.live-spec-fence
.claude/worktrees/

# rendered doc pages (render-doc.py output) are not committed
*.html

# frozen norms are SOURCE artifacts, never regenerable junk — always tracked
!docs/norms/*.html
# test fixtures are SOURCE too — the suite reads them, they must be tracked
!tests/fixtures/*.html
.claude/

# spec-freeze working baselines (regenerable from the pre-rewrite commit)
.spec-freeze/
